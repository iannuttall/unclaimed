{
  "name": "unclaimed",
  "version": "0.1.0",
  "description": "Find and track available single-word domains from your terminal.",
  "author": "Ian Nuttall",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "unclaimed": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "keywords": [
    "domain",
    "domains",
    "availability",
    "rdap",
    "whois",
    "cli",
    "agents"
  ],
  "homepage": "https://github.com/iannuttall/unclaimed#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iannuttall/unclaimed.git"
  },
  "bugs": {
    "url": "https://github.com/iannuttall/unclaimed/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "lint": "tsc -p tsconfig.json --noEmit && node --check dist/cli.js",
    "prepack": "pnpm run build && pnpm run test",
    "test": "node --import tsx --test tests/*.test.mjs tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@unclaimed/core": "workspace:*",
    "@types/react": "^19.2.17",
    "tsdown": "^0.22.7",
    "tsx": "^4.23.1"
  }
}
