{
  "name": "unclaimed-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:words": "node scripts/build-wordlist.mjs",
    "check": "pnpm build && pnpm typecheck && pnpm test && pnpm lint",
    "clean": "turbo run clean",
    "dev": "UNCLAIMED_DB=./data/domains.db tsx --tsconfig packages/cli/tsconfig.json packages/cli/src/cli.ts",
    "domains": "UNCLAIMED_DB=./data/domains.db tsx --tsconfig packages/cli/tsconfig.json packages/cli/src/cli.ts",
    "lint": "biome check . && turbo run lint",
    "lint:fix": "biome check . --write",
    "pack:dry-run": "pnpm --filter unclaimed pack --dry-run",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "unclaimed": "UNCLAIMED_DB=./data/domains.db tsx --tsconfig packages/cli/tsconfig.json packages/cli/src/cli.ts",
    "worker:deploy:dry-run": "pnpm --filter @unclaimed/worker deploy:dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^24.0.0",
    "turbo": "^2.10.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "wordnet-db": "^3.1.14"
  }
}
